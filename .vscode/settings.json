{
  "python.defaultInterpreterPath": "${workspaceFolder}/python/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.envFile": "${workspaceFolder}/.env",
  "editor.formatOnSave": true,
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.python"
  },
  "files.exclude": {
    "**/.venv": false,
    "**/__pycache__": true,
    "**/.terraform": true
  },
  "dotnet.defaultSolution": "Bob.sln",
  "omnisharp.useModernNet": true,
  "omnisharp.enableRoslynAnalyzers": true,
  "dotnet.preferCSharpExtension": true,
  "unity.editorPath": "/Applications/Unity/Hub/Editor/6000.5.0f1/Unity.app",
  "unity.projectPath": "${workspaceFolder}",
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.env.osx": {
    "UNITY_VERSION": "6000.5.0f1",
    "UNITY_PROJECT_PATH": "${workspaceFolder}"
  }
}
