# Unity Editor path (optional override)
UNITY_VERSION=6000.5.0f1
UNITY_PROJECT_PATH=

# ML-Agents training defaults
RUN_ID=bob-v0
CONFIG=config/bob_free_throw.yaml

# Unity AI Gateway — xAI Grok BYOM (via Codex agent; never commit real keys)
# Retrieve from macOS Keychain:
#   security find-generic-password -s "XAI_API_KEY" -a "xai" -w
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.3
UNITY_AI_GATEWAY_AGENT=codex
# Codex OpenAI-compatible wire (same key as XAI_API_KEY)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.x.ai/v1
